#!/usr/bin/env python3
import os
import sys
import subprocess
import tempfile
import webbrowser
import requests

def check_dependencies():
    dependencies = {
        'slurp': 'slurp (Wayland region selector)',
        'grim': 'grim (Wayland screenshot tool)',
        'wl-copy': 'wl-clipboard (Wayland clipboard utilities)'
    }
    
    missing = []
    for cmd, description in dependencies.items():
        if subprocess.call(['which', cmd], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) != 0:
            missing.append(description)
            
    if missing:
        print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", file=sys.stderr)
        print(" ❌ ERROR: Missing Required System Dependencies", file=sys.stderr)
        print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", file=sys.stderr)
        print("This tool requires a Wayland compositor and the following utilities:", file=sys.stderr)
        for item in missing:
            print(f"  • {item}", file=sys.stderr)
        print("\nFix this by running:", file=sys.stderr)
        print("  sudo pacman -S grim slurp wl-clipboard", file=sys.stderr)
        print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", file=sys.stderr)
        sys.exit(1)

def take_screenshot(tmp_path):
    print("Select a region to search...")
    cmd = f'grim -g "$(slurp)" "{tmp_path}"'
    result = subprocess.run(cmd, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)
    if result.returncode != 0:
        print("Selection cancelled.", file=sys.stderr)
        sys.exit(0)

def copy_to_clipboard(tmp_path):
    try:
        with open(tmp_path, 'rb') as f:
            subprocess.run(['wl-copy', '-t', 'image/png'], stdin=f)
    except Exception:
        pass

def upload_and_get_lens_url(image_path):
    print("Uploading selection anonymously to Imgur...")
    
    # Standard open client ID used globally for open-source screenshot integrations
    imgur_url = "https://api.imgur.com/3/image"
    headers = {"Authorization": "Client-ID 546c25a59c58ad7"}
    
    try:
        with open(image_path, 'rb') as img_file:
            files = {'image': img_file}
            response = requests.post(imgur_url, headers=headers, files=files)
            
            if response.status_code == 200:
                data = response.json()
                hosted_url = data['data']['link']
                
                # Construct the official Google Lens endpoint string
                return f"https://lens.google.com/uploadbyurl?url={hosted_url}"
            else:
                print(f"Imgur API Error: {response.status_code} - {response.text}", file=sys.stderr)
                sys.exit(1)
    except Exception as e:
        print(f"Network error executing Imgur API handshake: {e}", file=sys.stderr)
        sys.exit(1)

def open_browser(url):
    try:
        print("Opening Google Lens results in Chromium...")
        subprocess.Popen(['chromium', url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except FileNotFoundError:
        print("Chromium binary target not found. Falling back to system default browser...")
        webbrowser.open(url)

def main():
    check_dependencies()
    with tempfile.NamedTemporaryFile(suffix='.png', delete=False) as tmp:
        tmp_path = tmp.name
    try:
        take_screenshot(tmp_path)
        copy_to_clipboard(tmp_path)
        lens_url = upload_and_get_lens_url(tmp_path)
        if lens_url:
            open_browser(lens_url)
    finally:
        if os.path.exists(tmp_path):
            os.remove(tmp_path)

if __name__ == "__main__":
    main()
